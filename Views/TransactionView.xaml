<UserControl x:Class="LibraryManagementSystem.Views.TransactionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Transaction list -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Content="Active only" VerticalAlignment="Center"
                          IsChecked="{Binding ShowActiveOnly}"/>
                <Button Grid.Column="1" Content="↺ Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}" Margin="6,0,0,0"/>
                <Button Grid.Column="2" Content="↩ Return Selected"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ReturnCommand}" Margin="6,0,0,0"/>
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Transactions}"
                      SelectedItem="{Binding SelectedTransaction}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"          Binding="{Binding Id}"                              Width="45"/>
                    <DataGridTextColumn Header="Book"        Binding="{Binding Book.Title}"                      Width="*"/>
                    <DataGridTextColumn Header="Member"      Binding="{Binding Member.Name}"                     Width="140"/>
                    <DataGridTextColumn Header="Borrowed"    Binding="{Binding BorrowDate, StringFormat=d}"      Width="90"/>
                    <DataGridTextColumn Header="Due"         Binding="{Binding DueDate, StringFormat=d}"         Width="90"/>
                    <DataGridTextColumn Header="Returned"    Binding="{Binding ReturnDate, StringFormat=d}"      Width="90"/>
                    <DataGridTemplateColumn Header="Status"  Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReturned}" Value="True">
                                                    <Setter Property="Text"       Value="✅ Returned"/>
                                                    <Setter Property="Foreground" Value="#2DC653"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Text"       Value="⚠️ Overdue"/>
                                                    <Setter Property="Foreground" Value="#E63946"/>
                                                </DataTrigger>
                                                <Setter Property="Text"           Value="📖 Active"/>
                                                <Setter Property="Foreground"     Value="#048A81"/>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- RIGHT: Borrow form -->
        <Border Grid.Column="1" Background="White" CornerRadius="8"
                BorderBrush="#CDD3DB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="Borrow a Book" FontSize="16" FontWeight="Bold"
                           Foreground="#2E4057" Margin="0,0,0,16"/>

                <Label Content="Select Book"/>
                <ComboBox ItemsSource="{Binding AvailableBooks}"
                          SelectedItem="{Binding SelectedBook}"
                          DisplayMemberPath="Title"
                          Margin="0,0,0,10" Padding="8,6"/>

                <Label Content="Select Member"/>
                <ComboBox ItemsSource="{Binding AllMembers}"
                          SelectedItem="{Binding SelectedMember}"
                          DisplayMemberPath="Name"
                          Margin="0,0,0,10" Padding="8,6"/>

                <Label Content="Due Date"/>
                <DatePicker SelectedDate="{Binding DueDate}" Margin="0,0,0,16"/>

                <Button Content="📚 Borrow Book"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BorrowCommand}"/>

                <Separator Margin="0,16"/>

                <TextBlock Text="Select a row and click 'Return Selected' above to return a book."
                           TextWrapping="Wrap" Foreground="#888" FontSize="11"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#048A81"
                           FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
