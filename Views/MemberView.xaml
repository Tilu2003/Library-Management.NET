<UserControl x:Class="LibraryManagementSystem.Views.MemberView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Member list -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10,8"/>
                <Button Grid.Column="1" Content="↺ Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}" Margin="6,0,0,0"/>
            </Grid>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Members}"
                      SelectedItem="{Binding SelectedMember}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"              Binding="{Binding Id}"             Width="50"/>
                    <DataGridTextColumn Header="Name"            Binding="{Binding Name}"           Width="*"/>
                    <DataGridTextColumn Header="Contact Info"    Binding="{Binding ContactInfo}"    Width="200"/>
                    <DataGridTextColumn Header="Membership Date" Binding="{Binding MembershipDate, StringFormat=d}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- RIGHT: Form -->
        <Border Grid.Column="1" Background="White" CornerRadius="8"
                BorderBrush="#CDD3DB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="Member Details" FontSize="16" FontWeight="Bold"
                           Foreground="#2E4057" Margin="0,0,0,16"/>

                <Label Content="Full Name *"/>
                <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Contact Info *"/>
                <TextBox Text="{Binding FormContactInfo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Membership Date"/>
                <DatePicker SelectedDate="{Binding FormMembershipDate}" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="➕ Add"    Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommand}"    Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="✏️ Update" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateCommand}" Margin="4,0,0,0"/>
                </Grid>
                <Button Content="🗑️ Delete" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}" Margin="0,6,0,6"/>
                <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearCommand}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#048A81"
                           FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
