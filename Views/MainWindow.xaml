<Window x:Class="LibraryManagementSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryManagementSystem.Views"
        Title="📚 Library Management System"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2E4057">
            <Grid Margin="20,0">
                <TextBlock Text="📚 Library Management System"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Intern Training Project — OOP with C# + WPF + EF Core"
                           Foreground="#A0B0C0" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="10">

            <!-- Books Tab -->
            <TabItem Header="📖  Books">
                <views:BookView DataContext="{Binding BookVM}"/>
            </TabItem>

            <!-- Members Tab -->
            <TabItem Header="👥  Members">
                <views:MemberView DataContext="{Binding MemberVM}"/>
            </TabItem>

            <!-- Transactions Tab -->
            <TabItem Header="🔄  Borrowing">
                <views:TransactionView DataContext="{Binding TransactionVM}"/>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#2E4057">
            <StatusBarItem>
                <TextBlock Text="{Binding BookVM.StatusMessage}" Foreground="White" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
