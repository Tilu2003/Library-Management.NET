<UserControl x:Class="LibraryManagementSystem.Views.BookView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Book list -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search bar -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Padding="10,8"/>
                <Button Grid.Column="1" Content="Refresh"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding LoadCommand}"
                        Margin="6,0,0,0"/>
            </Grid>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Books}"
                      SelectedItem="{Binding SelectedBook}"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"     Binding="{Binding Id}"     Width="50"/>
                    <DataGridTextColumn Header="Title"  Binding="{Binding Title}"  Width="*"/>
                    <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="180"/>
                    <DataGridTextColumn Header="ISBN"   Binding="{Binding ISBN}"   Width="130"/>
                    <DataGridTextColumn Header="Genre"  Binding="{Binding Genre}"  Width="100"/>
                    <DataGridTemplateColumn Header="Available" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Yes"/>
                                            <Setter Property="Foreground" Value="#2DC653"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                    <Setter Property="Text" Value="No"/>
                                                    <Setter Property="Foreground" Value="#E63946"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- RIGHT: Add/Edit Form -->
        <Border Grid.Column="1" Background="White" CornerRadius="8"
                BorderBrush="#CDD3DB" BorderThickness="1" Padding="16">
            <StackPanel>
                <TextBlock Text="Book Details" FontSize="16" FontWeight="Bold"
                           Foreground="#2E4057" Margin="0,0,0,16"/>

                <Label Content="Title *"/>
                <TextBox Text="{Binding FormTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Author *"/>
                <TextBox Text="{Binding FormAuthor, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="ISBN *"/>
                <TextBox Text="{Binding FormISBN, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <Label Content="Genre"/>
                <TextBox Text="{Binding FormGenre, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <CheckBox Content="Available" IsChecked="{Binding FormIsAvailable}" Margin="0,0,0,16"/>

                <!-- Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Add"    Style="{StaticResource PrimaryButton}"
                            Command="{Binding AddCommand}"  Margin="0,0,4,0"/>
                    <Button Grid.Column="1" Content="Update" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateCommand}" Margin="4,0,0,0"/>
                </Grid>
                <Button Content="Delete" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}" Margin="0,6,0,6"/>
                <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearCommand}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="#048A81"
                           FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
